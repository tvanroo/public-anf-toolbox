{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "automationAccountName": {
      "type": "string",
      "defaultValue": "[concat('ANF-Weekend-Scaling-', take(uniqueString(resourceGroup().id, deployment().name), 6))]",
      "metadata": {
        "description": "Automation Account name. Change this if the name already exists in the deployment resource group, or clear it to generate a unique name."
      }
    },
    "capacityPoolResourceId": {
      "type": "string",
      "metadata": {
        "description": "Full Resource ID of the initial Azure NetApp Files capacity pool."
      }
    },
    "testMode": {
      "type": "string",
      "defaultValue": "Yes",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Yes = preview only. No = create target pool, move volumes, and remove the previous source pool."
      }
    },
    "weekdayPoolName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Weekday target pool name. Leave blank to use <initial-pool>-weekday."
      }
    },
    "weekendPoolName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Weekend target pool name. Leave blank to use <initial-pool>-weekend."
      }
    },
    "weekdayServiceLevel": {
      "type": "string",
      "defaultValue": "Ultra",
      "allowedValues": [
        "Standard",
        "Premium",
        "Ultra"
      ],
      "metadata": {
        "description": "Service level for the weekday pool."
      }
    },
    "weekendServiceLevel": {
      "type": "string",
      "defaultValue": "Standard",
      "allowedValues": [
        "Standard",
        "Premium",
        "Ultra"
      ],
      "metadata": {
        "description": "Service level for the weekend pool."
      }
    },
    "weekendStartDay": {
      "type": "string",
      "defaultValue": "Friday",
      "allowedValues": [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
        "Sunday"
      ],
      "metadata": {
        "description": "Day when the weekend window starts."
      }
    },
    "weekendStartTime": {
      "type": "string",
      "defaultValue": "18:00",
      "metadata": {
        "description": "Time when the weekend window starts, in HH:mm format."
      }
    },
    "weekendFullDays": {
      "type": "string",
      "defaultValue": "Saturday,Sunday",
      "metadata": {
        "description": "Comma-separated days that are fully in the weekend window."
      }
    },
    "weekendEndDay": {
      "type": "string",
      "defaultValue": "Monday",
      "allowedValues": [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
        "Sunday"
      ],
      "metadata": {
        "description": "Day when the weekend window ends."
      }
    },
    "weekendEndTime": {
      "type": "string",
      "defaultValue": "06:00",
      "metadata": {
        "description": "Time when the weekend window ends, in HH:mm format."
      }
    },
    "timeZone": {
      "type": "string",
      "defaultValue": "Central Standard Time",
      "metadata": {
        "description": "Time zone ID used by the runbook to evaluate the weekend window."
      }
    },
    "scheduleStartDelayMinutes": {
      "type": "int",
      "defaultValue": 20,
      "minValue": 1,
      "metadata": {
        "description": "Minutes from deployment time until the first scheduled run starts."
      }
    },
    "runbookScriptUri": {
      "type": "string",
      "defaultValue": "https://raw.githubusercontent.com/tvanroo/public-anf-toolbox/codex/weekend-scaling-modernization/ANF%20Weekend%20Scaling%20Plan/anf-weekend-scaling-plan.ps1",
      "metadata": {
        "description": "Source URL of the runbook script file to import and publish."
      }
    }
  },
  "variables": {
    "sharedTemplateUri": "https://raw.githubusercontent.com/tvanroo/public-anf-toolbox/codex/weekend-scaling-modernization/ANF%20Weekend%20Scaling%20Plan/deploy/azuredeploy.json",
    "editableTestModeVariable": "ANF_TestMode",
    "editableCapacityPoolResourceIdVariable": "ANF_CapacityPoolResourceId",
    "editableWeekdayPoolNameVariable": "ANF_WeekdayPoolName",
    "editableWeekendPoolNameVariable": "ANF_WeekendPoolName"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "name": "anf-weekend-scaling-gov",
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "[variables('sharedTemplateUri')]",
          "contentVersion": "1.0.0.0"
        },
        "parameters": {
          "automationAccountName": {
            "value": "[parameters('automationAccountName')]"
          },
          "capacityPoolResourceId": {
            "value": "[parameters('capacityPoolResourceId')]"
          },
          "testMode": {
            "value": "[parameters('testMode')]"
          },
          "weekdayPoolName": {
            "value": "[parameters('weekdayPoolName')]"
          },
          "weekendPoolName": {
            "value": "[parameters('weekendPoolName')]"
          },
          "weekdayServiceLevel": {
            "value": "[parameters('weekdayServiceLevel')]"
          },
          "weekendServiceLevel": {
            "value": "[parameters('weekendServiceLevel')]"
          },
          "weekendStartDay": {
            "value": "[parameters('weekendStartDay')]"
          },
          "weekendStartTime": {
            "value": "[parameters('weekendStartTime')]"
          },
          "weekendFullDays": {
            "value": "[parameters('weekendFullDays')]"
          },
          "weekendEndDay": {
            "value": "[parameters('weekendEndDay')]"
          },
          "weekendEndTime": {
            "value": "[parameters('weekendEndTime')]"
          },
          "timeZone": {
            "value": "[parameters('timeZone')]"
          },
          "scheduleStartDelayMinutes": {
            "value": "[parameters('scheduleStartDelayMinutes')]"
          },
          "runbookScriptUri": {
            "value": "[parameters('runbookScriptUri')]"
          }
        }
      }
    }
  ],
  "outputs": {
    "testModeVariable": {
      "type": "string",
      "value": "[variables('editableTestModeVariable')]"
    },
    "capacityPoolResourceIdVariable": {
      "type": "string",
      "value": "[variables('editableCapacityPoolResourceIdVariable')]"
    },
    "weekdayPoolNameVariable": {
      "type": "string",
      "value": "[variables('editableWeekdayPoolNameVariable')]"
    },
    "weekendPoolNameVariable": {
      "type": "string",
      "value": "[variables('editableWeekendPoolNameVariable')]"
    }
  }
}
