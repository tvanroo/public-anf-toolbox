{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "automationAccountName": {
      "type": "string",
      "defaultValue": "[concat('ANF-Weekend-Scaling-', take(uniqueString(resourceGroup().id, deployment().name), 6))]",
      "metadata": {
        "description": "Automation Account name. Change this if the name already exists in the deployment resource group, or clear it to generate a unique name."
      }
    },
    "capacityPoolResourceId": {
      "type": "string",
      "metadata": {
        "description": "Full Resource ID of the initial Azure NetApp Files capacity pool. The initial pool may be removed after the first run; the Resource ID still identifies the managed pool set."
      }
    },
    "testMode": {
      "type": "string",
      "defaultValue": "Yes",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Yes = preview only. No = create target pool, move volumes, and remove the previous source pool."
      }
    },
    "weekdayServiceLevel": {
      "type": "string",
      "defaultValue": "Ultra",
      "allowedValues": [
        "Standard",
        "Premium",
        "Ultra"
      ],
      "metadata": {
        "description": "Service level for the weekday pool."
      }
    },
    "weekendServiceLevel": {
      "type": "string",
      "defaultValue": "Standard",
      "allowedValues": [
        "Standard",
        "Premium",
        "Ultra"
      ],
      "metadata": {
        "description": "Service level for the weekend pool."
      }
    },
    "weekendStartDay": {
      "type": "string",
      "defaultValue": "Friday",
      "allowedValues": [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
        "Sunday"
      ],
      "metadata": {
        "description": "Day when the weekend window starts."
      }
    },
    "weekendStartTime": {
      "type": "string",
      "defaultValue": "18:00",
      "metadata": {
        "description": "Time when the weekend window starts, in HH:mm format."
      }
    },
    "weekendFullDays": {
      "type": "string",
      "defaultValue": "Saturday,Sunday",
      "metadata": {
        "description": "Comma-separated days that are fully in the weekend window."
      }
    },
    "weekendEndDay": {
      "type": "string",
      "defaultValue": "Monday",
      "allowedValues": [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
        "Sunday"
      ],
      "metadata": {
        "description": "Day when the weekend window ends."
      }
    },
    "weekendEndTime": {
      "type": "string",
      "defaultValue": "06:00",
      "metadata": {
        "description": "Time when the weekend window ends, in HH:mm format."
      }
    },
    "timeZone": {
      "type": "string",
      "defaultValue": "Central Standard Time",
      "allowedValues": [
        "UTC",
        "Dateline Standard Time",
        "UTC-11",
        "Aleutian Standard Time",
        "Hawaiian Standard Time",
        "Alaskan Standard Time",
        "Pacific Standard Time",
        "US Mountain Standard Time",
        "Mountain Standard Time",
        "Central Standard Time",
        "Eastern Standard Time",
        "Atlantic Standard Time",
        "Newfoundland Standard Time",
        "SA Western Standard Time",
        "E. South America Standard Time",
        "Argentina Standard Time",
        "UTC-02",
        "Azores Standard Time",
        "Cape Verde Standard Time",
        "GMT Standard Time",
        "Greenwich Standard Time",
        "Morocco Standard Time",
        "W. Europe Standard Time",
        "Central Europe Standard Time",
        "Romance Standard Time",
        "Central European Standard Time",
        "South Africa Standard Time",
        "Egypt Standard Time",
        "FLE Standard Time",
        "GTB Standard Time",
        "Turkey Standard Time",
        "Israel Standard Time",
        "Arabic Standard Time",
        "Arabian Standard Time",
        "E. Africa Standard Time",
        "Iran Standard Time",
        "Afghanistan Standard Time",
        "Pakistan Standard Time",
        "India Standard Time",
        "Sri Lanka Standard Time",
        "Nepal Standard Time",
        "Central Asia Standard Time",
        "Bangladesh Standard Time",
        "Myanmar Standard Time",
        "SE Asia Standard Time",
        "China Standard Time",
        "Singapore Standard Time",
        "Taipei Standard Time",
        "W. Australia Standard Time",
        "Tokyo Standard Time",
        "Korea Standard Time",
        "AUS Central Standard Time",
        "AUS Eastern Standard Time",
        "E. Australia Standard Time",
        "Tasmania Standard Time",
        "West Pacific Standard Time",
        "New Zealand Standard Time",
        "UTC+12",
        "Fiji Standard Time",
        "Tonga Standard Time",
        "Samoa Standard Time"
      ],
      "metadata": {
        "description": "Time zone ID used by the runbook to evaluate the weekend window."
      }
    },
    "scheduleStartDelayMinutes": {
      "type": "int",
      "defaultValue": 20,
      "minValue": 1,
      "metadata": {
        "description": "Minutes from deployment time until the first scheduled run starts."
      }
    },
    "scheduleBaseTimeUtc": {
      "type": "string",
      "defaultValue": "[utcNow('u')]",
      "metadata": {
        "description": "Deployment timestamp used to calculate the first scheduled run. Leave the default value."
      }
    },
    "runbookScriptUri": {
      "type": "string",
      "defaultValue": "https://raw.githubusercontent.com/tvanroo/public-anf-toolbox/codex/weekend-scaling-modernization/ANF%20Weekend%20Scaling%20Plan/anf-weekend-scaling-plan.ps1",
      "metadata": {
        "description": "Source URL of the runbook script file to import and publish."
      }
    }
  },
  "variables": {
    "automationAccountName": "[if(empty(parameters('automationAccountName')), toLower(concat('aa-anf-weekend-', take(uniqueString(resourceGroup().id, deployment().name), 8))), parameters('automationAccountName'))]",
    "capacityPoolResourceIdParts": "[split(parameters('capacityPoolResourceId'), '/')]",
    "targetAnfSubscriptionId": "[variables('capacityPoolResourceIdParts')[2]]",
    "targetAnfResourceGroupName": "[variables('capacityPoolResourceIdParts')[4]]",
    "targetAnfAccountName": "[variables('capacityPoolResourceIdParts')[8]]",
    "targetAnfAccountResourceId": "[format('/subscriptions/{0}/resourceGroups/{1}/providers/Microsoft.NetApp/netAppAccounts/{2}', variables('targetAnfSubscriptionId'), variables('targetAnfResourceGroupName'), variables('targetAnfAccountName'))]",
    "runbookName": "ANF-Weekend-Scaling-Plan",
    "scheduleName": "anf-weekend-scaling-hourly",
    "jobScheduleName": "[guid(resourceGroup().id, variables('automationAccountName'), variables('runbookName'), variables('scheduleName'))]",
    "rbacDeploymentName": "[concat('anf-weekend-scaling-rbac-', take(uniqueString(variables('targetAnfAccountResourceId'), variables('automationAccountName')), 8))]",
    "anfAdministratorRoleName": "Azure NetApp Files Administrator",
    "anfAdministratorRoleDefinitionId": "f5db7409-a2c6-4d0c-8cf4-412ac01a38df",
    "standardTags": {
      "managed-by": "public-anf-toolbox",
      "solution": "anf-weekend-scaling-plan",
      "repository": "https://github.com/tvanroo/public-anf-toolbox",
      "documentation": "https://github.com/tvanroo/public-anf-toolbox/tree/codex/weekend-scaling-modernization/ANF%20Weekend%20Scaling%20Plan",
      "script": "anf-weekend-scaling-plan.ps1",
      "status": "wip"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Automation/automationAccounts",
      "apiVersion": "2023-11-01",
      "name": "[variables('automationAccountName')]",
      "location": "[resourceGroup().location]",
      "identity": {
        "type": "SystemAssigned"
      },
      "tags": "[variables('standardTags')]",
      "properties": {
        "sku": {
          "name": "Basic"
        },
        "publicNetworkAccess": true
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/modules",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/Az.Accounts')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "contentLink": {
          "uri": "https://www.powershellgallery.com/api/v2/package/Az.Accounts"
        }
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "name": "[variables('rbacDeploymentName')]",
      "subscriptionId": "[variables('targetAnfSubscriptionId')]",
      "resourceGroup": "[variables('targetAnfResourceGroupName')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "targetAnfAccountName": {
              "type": "string"
            },
            "targetAnfAccountResourceId": {
              "type": "string"
            },
            "automationPrincipalId": {
              "type": "string"
            },
            "anfAdministratorRoleDefinitionId": {
              "type": "string"
            }
          },
          "resources": [
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[format('Microsoft.NetApp/netAppAccounts/{0}', parameters('targetAnfAccountName'))]",
              "name": "[guid(parameters('targetAnfAccountResourceId'), parameters('automationPrincipalId'), parameters('anfAdministratorRoleDefinitionId'))]",
              "properties": {
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', parameters('anfAdministratorRoleDefinitionId'))]",
                "principalId": "[parameters('automationPrincipalId')]",
                "principalType": "ServicePrincipal"
              }
            }
          ]
        },
        "parameters": {
          "targetAnfAccountName": {
            "value": "[variables('targetAnfAccountName')]"
          },
          "targetAnfAccountResourceId": {
            "value": "[variables('targetAnfAccountResourceId')]"
          },
          "automationPrincipalId": {
            "value": "[reference(resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName')), '2023-11-01', 'Full').identity.principalId]"
          },
          "anfAdministratorRoleDefinitionId": {
            "value": "[variables('anfAdministratorRoleDefinitionId')]"
          }
        }
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_TenantId')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Target Azure tenant ID.",
        "value": "[concat('\"', tenant().tenantId, '\"')]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_CapacityPoolResourceId')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "One or more initial capacity pool Resource IDs. Separate multiple IDs with new lines, semicolons, or commas.",
        "value": "[concat('\"', parameters('capacityPoolResourceId'), '\"')]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_TestMode')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Runbook mode. Yes=preview only. No=live changes.",
        "value": "[concat('\"', parameters('testMode'), '\"')]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_WeekdayServiceLevel')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Weekday service level. Standard, Premium, or Ultra.",
        "value": "[concat('\"', parameters('weekdayServiceLevel'), '\"')]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_WeekendServiceLevel')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Weekend service level. Standard, Premium, or Ultra.",
        "value": "[concat('\"', parameters('weekendServiceLevel'), '\"')]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_WeekendStartDay')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Weekend window start day.",
        "value": "[concat('\"', parameters('weekendStartDay'), '\"')]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_WeekendStartTime')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Weekend window start time in HH:mm format.",
        "value": "[concat('\"', parameters('weekendStartTime'), '\"')]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_WeekendFullDays')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Comma-separated full weekend days.",
        "value": "[concat('\"', parameters('weekendFullDays'), '\"')]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_WeekendEndDay')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Weekend window end day.",
        "value": "[concat('\"', parameters('weekendEndDay'), '\"')]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_WeekendEndTime')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Weekend window end time in HH:mm format.",
        "value": "[concat('\"', parameters('weekendEndTime'), '\"')]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_TimeZone')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Time zone ID used by the runbook to evaluate the weekend schedule.",
        "value": "[concat('\"', parameters('timeZone'), '\"')]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/runbooks",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/', variables('runbookName'))]",
      "location": "[resourceGroup().location]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts/modules', variables('automationAccountName'), 'Az.Accounts')]"
      ],
      "tags": "[variables('standardTags')]",
      "properties": {
        "description": "ANF Weekend Scaling Plan runbook for classic Standard, Premium, and Ultra Auto QoS pools.",
        "runbookType": "PowerShell72",
        "logProgress": true,
        "logVerbose": true,
        "publishContentLink": {
          "uri": "[parameters('runbookScriptUri')]",
          "version": "1.0.0.0"
        }
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/schedules",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/', variables('scheduleName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "description": "Hourly schedule for ANF Weekend Scaling Plan runbook.",
        "startTime": "[dateTimeAdd(parameters('scheduleBaseTimeUtc'), concat('PT', parameters('scheduleStartDelayMinutes'), 'M'))]",
        "frequency": "Hour",
        "interval": 1,
        "timeZone": "UTC"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/jobSchedules",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/', variables('jobScheduleName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts/runbooks', variables('automationAccountName'), variables('runbookName'))]",
        "[resourceId('Microsoft.Automation/automationAccounts/schedules', variables('automationAccountName'), variables('scheduleName'))]"
      ],
      "properties": {
        "schedule": {
          "name": "[variables('scheduleName')]"
        },
        "runbook": {
          "name": "[variables('runbookName')]"
        }
      }
    }
  ],
  "outputs": {
    "automationAccountName": {
      "type": "string",
      "value": "[variables('automationAccountName')]"
    },
    "runbookName": {
      "type": "string",
      "value": "[variables('runbookName')]"
    },
    "testModeVariable": {
      "type": "string",
      "value": "ANF_TestMode"
    },
    "capacityPoolResourceIdVariable": {
      "type": "string",
      "value": "ANF_CapacityPoolResourceId"
    },
    "weekdayServiceLevelVariable": {
      "type": "string",
      "value": "ANF_WeekdayServiceLevel"
    },
    "weekendServiceLevelVariable": {
      "type": "string",
      "value": "ANF_WeekendServiceLevel"
    },
    "managedIdentityPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName')), '2023-11-01', 'Full').identity.principalId]"
    },
    "rbac": {
      "type": "string",
      "value": "[concat('Assigned ', variables('anfAdministratorRoleName'), ' at the target ANF account scope: ', variables('targetAnfAccountResourceId'))]"
    }
  }
}
