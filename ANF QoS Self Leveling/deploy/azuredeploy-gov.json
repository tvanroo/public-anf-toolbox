{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "automationAccountName": {
      "type": "string",
      "defaultValue": "[concat('ANF-QoS-SelfLeveling-', take(uniqueString(resourceGroup().id, deployment().name), 6))]",
      "metadata": {
        "description": "Automation Account name. Change this if the name already exists in the deployment resource group, or clear it to generate a unique name."
      }
    },
    "capacityPoolResourceId": {
      "type": "string",
      "metadata": {
        "description": "Full Resource ID of the initial Azure NetApp Files capacity pool. After deployment, edit ANF_CapacityPoolResourceId to add more pool IDs if needed."
      }
    },
    "testMode": {
      "type": "string",
      "defaultValue": "Yes",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Yes = preview only. No = apply live QoS and throughput changes."
      }
    },
    "convertToManualMode": {
      "type": "string",
      "defaultValue": "Yes",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Yes allows classic Standard/Premium/Ultra Auto QoS pools to be converted to Manual QoS."
      }
    },
    "minimumThroughputPerVolume": {
      "type": "int",
      "defaultValue": 1,
      "minValue": 1,
      "metadata": {
        "description": "Per-volume throughput floor in MiB/s."
      }
    },
    "throughputLookBackHours": {
      "type": "int",
      "defaultValue": 24,
      "minValue": 1,
      "metadata": {
        "description": "Lookback window in hours for throughputLimitReached pressure."
      }
    },
    "decreaseRequiredCleanDays": {
      "type": "int",
      "defaultValue": 3,
      "minValue": 1,
      "metadata": {
        "description": "Clean trailing 24-hour windows required before throughput decreases are allowed."
      }
    },
    "levelingAgressionPercent": {
      "type": "int",
      "defaultValue": 10,
      "minValue": 1,
      "metadata": {
        "description": "How aggressively to rebalance each run. This is the percent of movable throughput shifted in one run."
      }
    },
    "throughputLimitMetricAllowance": {
      "type": "int",
      "defaultValue": 0,
      "minValue": 0,
      "metadata": {
        "description": "Maximum acceptable throughputLimitReached average before a volume is treated as constrained."
      }
    },
    "excludeTagKey": {
      "type": "string",
      "defaultValue": "ExcludeFromAnfQosSelfLeveling",
      "metadata": {
        "description": "Volume tag key used to exclude volumes from self-leveling."
      }
    },
    "excludeTagValue": {
      "type": "string",
      "defaultValue": "true",
      "metadata": {
        "description": "Volume tag value used with excludeTagKey."
      }
    },
    "scheduleStartDelayMinutes": {
      "type": "int",
      "defaultValue": 20,
      "minValue": 1,
      "metadata": {
        "description": "Minutes from deployment time until the first scheduled run starts."
      }
    },
    "runbookScriptUri": {
      "type": "string",
      "defaultValue": "https://raw.githubusercontent.com/tvanroo/public-anf-toolbox/codex/qos-self-leveling-modernization/ANF%20QoS%20Self%20Leveling/ANF-QoS-Autoscale-SelfLeveling.ps1",
      "metadata": {
        "description": "Source URL of the runbook script file to import and publish."
      }
    }
  },
  "variables": {
    "sharedTemplateUri": "https://raw.githubusercontent.com/tvanroo/public-anf-toolbox/codex/qos-self-leveling-modernization/ANF%20QoS%20Self%20Leveling/deploy/azuredeploy.json"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "name": "anf-qos-selfleveling-gov",
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "[variables('sharedTemplateUri')]",
          "contentVersion": "1.0.0.0"
        },
        "parameters": {
          "automationAccountName": {
            "value": "[parameters('automationAccountName')]"
          },
          "capacityPoolResourceId": {
            "value": "[parameters('capacityPoolResourceId')]"
          },
          "testMode": {
            "value": "[parameters('testMode')]"
          },
          "convertToManualMode": {
            "value": "[parameters('convertToManualMode')]"
          },
          "minimumThroughputPerVolume": {
            "value": "[parameters('minimumThroughputPerVolume')]"
          },
          "throughputLookBackHours": {
            "value": "[parameters('throughputLookBackHours')]"
          },
          "decreaseRequiredCleanDays": {
            "value": "[parameters('decreaseRequiredCleanDays')]"
          },
          "levelingAgressionPercent": {
            "value": "[parameters('levelingAgressionPercent')]"
          },
          "throughputLimitMetricAllowance": {
            "value": "[parameters('throughputLimitMetricAllowance')]"
          },
          "excludeTagKey": {
            "value": "[parameters('excludeTagKey')]"
          },
          "excludeTagValue": {
            "value": "[parameters('excludeTagValue')]"
          },
          "scheduleStartDelayMinutes": {
            "value": "[parameters('scheduleStartDelayMinutes')]"
          },
          "runbookScriptUri": {
            "value": "[parameters('runbookScriptUri')]"
          }
        }
      }
    }
  ],
  "outputs": {
    "testModeVariable": {
      "type": "string",
      "value": "ANF_TestMode"
    },
    "capacityPoolResourceIdVariable": {
      "type": "string",
      "value": "ANF_CapacityPoolResourceId"
    },
    "levelingAgressionVariable": {
      "type": "string",
      "value": "ANF_LevelingAgressionPercent"
    },
    "throughputLimitMetricAllowanceVariable": {
      "type": "string",
      "value": "ANF_ThroughputLimitMetricAllowance"
    },
    "decreaseRequiredCleanDaysVariable": {
      "type": "string",
      "value": "ANF_DecreaseRequiredCleanDays"
    },
    "template": {
      "type": "string",
      "value": "Azure Government wrapper for ANF QoS Self Leveling deploy template."
    }
  }
}
