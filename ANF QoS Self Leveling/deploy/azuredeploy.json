{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "anfResourceGroupName": {
      "type": "string",
      "metadata": {
        "description": "Name of the resource group that contains the Azure NetApp Files account and pool you want to automate."
      }
    },
    "anfAccountName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Azure NetApp Files account to manage."
      }
    },
    "anfPoolName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Azure NetApp Files capacity pool to rebalance."
      }
    },
    "testMode": {
      "type": "string",
      "defaultValue": "Yes",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Test mode. Yes = preview only (no changes in Azure). No = apply live throughput changes."
      }
    },
    "levelingAgressionPercent": {
      "type": "int",
      "defaultValue": 10,
      "minValue": 1,
      "maxValue": 100,
      "metadata": {
        "description": "How aggressively to rebalance each run. This is the maximum percent of movable throughput shifted in one run. Lower = slower/safer, higher = faster/more change."
      }
    },
    "throughputLimitMetricAllowance": {
      "type": "int",
      "defaultValue": 6,
      "minValue": 0,
      "metadata": {
        "description": "Allowed throughput-limit incidents per day before a volume is treated as constrained and prioritized for more throughput."
      }
    },
    "scheduleTimeZone": {
      "type": "string",
      "defaultValue": "UTC",
      "metadata": {
        "description": "Time zone used by the daily run schedule (for example: UTC)."
      }
    },
    "scheduleStartTimeUtc": {
      "type": "string",
      "defaultValue": "[dateTimeAdd(utcNow('u'), 'PT15M')]",
      "metadata": {
        "description": "UTC start time for the first run. Default is deployment time + 15 minutes."
      }
    },
    "runbookScriptUri": {
      "type": "string",
      "defaultValue": "https://raw.githubusercontent.com/tvanroo/public-anf-toolbox/140094e3be0f4ab5df39072b71e63aa7d3707e82/ANF%20QoS%20Self%20Leveling/ANF-QoS-Autoscale-SelfLeveling-FSL.ps1",
      "metadata": {
        "description": "Source URL of the runbook script file to import and publish."
      }
    }
  },
  "variables": {
    "automationAccountName": "[toLower(concat('aa-anf-qos-fsl-', take(uniqueString(resourceGroup().id, deployment().name), 8)))]",
    "runbookName": "ANF-QoS-SelfLeveling-FSL",
    "scheduleName": "anf-qos-selfleveling-24h",
    "jobScheduleName": "[guid(resourceGroup().id, variables('automationAccountName'), variables('runbookName'), variables('scheduleName'))]",
    "standardTags": {
      "managed-by": "public-anf-toolbox",
      "solution": "anf-qos-self-leveling-fsl",
      "repository": "https://github.com/tvanroo/public-anf-toolbox",
      "documentation": "https://github.com/tvanroo/public-anf-toolbox/tree/main/ANF%20QoS%20Self%20Leveling",
      "script": "ANF-QoS-Autoscale-SelfLeveling-FSL.ps1"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Automation/automationAccounts",
      "apiVersion": "2023-11-01",
      "name": "[variables('automationAccountName')]",
      "location": "[resourceGroup().location]",
      "identity": {
        "type": "SystemAssigned"
      },
      "tags": "[variables('standardTags')]",
      "properties": {
        "sku": {
          "name": "Basic"
        },
        "publicNetworkAccess": true
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_ResourceGroupName')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Target ANF resource group.",
        "value": "[parameters('anfResourceGroupName')]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_AccountName')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Target ANF account name.",
        "value": "[parameters('anfAccountName')]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_PoolName')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Target ANF pool name.",
        "value": "[parameters('anfPoolName')]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_TestMode')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Runbook mode (Yes=preview, No=live).",
        "value": "[parameters('testMode')]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_LevelingAgressionPercent')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Leveling aggression percent.",
        "value": "[string(parameters('levelingAgressionPercent'))]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_ThroughputLimitMetricAllowance')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Throughput limit metric allowance.",
        "value": "[string(parameters('throughputLimitMetricAllowance'))]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/runbooks",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/', variables('runbookName'))]",
      "location": "[resourceGroup().location]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "tags": "[variables('standardTags')]",
      "properties": {
        "description": "ANF QoS Self Leveling FSL runbook. Docs: https://github.com/tvanroo/public-anf-toolbox/tree/main/ANF%20QoS%20Self%20Leveling",
        "runbookType": "PowerShell",
        "logProgress": true,
        "logVerbose": true,
        "publishContentLink": {
          "uri": "[parameters('runbookScriptUri')]",
          "version": "1.0.0.0"
        }
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/schedules",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/', variables('scheduleName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "description": "Daily 24-hour schedule for ANF QoS Self Leveling FSL runbook.",
        "startTime": "[parameters('scheduleStartTimeUtc')]",
        "frequency": "Day",
        "interval": 1,
        "timeZone": "[parameters('scheduleTimeZone')]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/jobSchedules",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/', variables('jobScheduleName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts/runbooks', variables('automationAccountName'), variables('runbookName'))]",
        "[resourceId('Microsoft.Automation/automationAccounts/schedules', variables('automationAccountName'), variables('scheduleName'))]"
      ],
      "properties": {
        "schedule": {
          "name": "[variables('scheduleName')]"
        },
        "runbook": {
          "name": "[variables('runbookName')]"
        }
      }
    }
  ],
  "outputs": {
    "automationAccountName": {
      "type": "string",
      "value": "[variables('automationAccountName')]"
    },
    "managedIdentityPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName')), '2023-11-01', 'Full').identity.principalId]"
    },
    "rbacNextStep": {
      "type": "string",
      "value": "Grant the Automation Account managed identity access to the target ANF scope before running live mode (for example, Contributor on the ANF resource group)."
    }
  }
}
