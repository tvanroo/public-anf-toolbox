{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "automationAccountName": {
      "type": "string",
      "defaultValue": "[concat('ANF-Capacity-Autoscale-', take(uniqueString(resourceGroup().id, deployment().name), 6))]",
      "metadata": {
        "description": "Automation Account name. Change this if the name already exists in the deployment resource group, or clear it to generate a unique name."
      }
    },
    "capacityPoolResourceId": {
      "type": "string",
      "metadata": {
        "description": "Full Resource ID of the target Azure NetApp Files capacity pool. Example: /subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/Microsoft.NetApp/netAppAccounts/<account>/capacityPools/<pool>"
      }
    },
    "testMode": {
      "type": "string",
      "defaultValue": "Yes",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Yes = preview only. No = apply live capacity and throughput changes."
      }
    },
    "capacityResizeThreshold": {
      "type": "int",
      "defaultValue": 99,
      "minValue": 1,
      "maxValue": 100,
      "metadata": {
        "description": "Expand a volume when max observed utilization is at or above this percent."
      }
    },
    "minimumFreeSpaceGiB": {
      "type": "int",
      "defaultValue": 256,
      "minValue": 1,
      "metadata": {
        "description": "Expand a volume when free space is at or below this value. Also used in target size calculations."
      }
    },
    "minimumVolumeGrowthPercent": {
      "type": "int",
      "defaultValue": 0,
      "minValue": 0,
      "metadata": {
        "description": "Minimum percent growth applied when expanding a volume."
      }
    },
    "maximumVolumeGrowthPercent": {
      "type": "int",
      "defaultValue": 10000000,
      "minValue": 1,
      "metadata": {
        "description": "Maximum percent growth allowed in one run."
      }
    },
    "capacityLookBackHours": {
      "type": "int",
      "defaultValue": 24,
      "minValue": 1,
      "metadata": {
        "description": "Lookback window for the VolumeLogicalSize metric."
      }
    },
    "volumeMinThroughputMap": {
      "type": "string",
      "defaultValue": "{}",
      "metadata": {
        "description": "JSON map of volume name to minimum MiB/s, for example {\"vol1\":10,\"vol2\":15}. Leave {} if not needed."
      }
    },
    "scheduleStartDelayMinutes": {
      "type": "int",
      "defaultValue": 20,
      "minValue": 1,
      "metadata": {
        "description": "Minutes from deployment time until the first scheduled run starts."
      }
    },
    "runbookScriptUri": {
      "type": "string",
      "defaultValue": "https://raw.githubusercontent.com/tvanroo/public-anf-toolbox/main/ANF%20Capacity%20Autoscale/ANF-Capacity-Autoscale.ps1",
      "metadata": {
        "description": "Source URL of the runbook script file to import and publish."
      }
    }
  },
  "variables": {
    "sharedTemplateUri": "https://raw.githubusercontent.com/tvanroo/public-anf-toolbox/main/ANF%20Capacity%20Autoscale/deploy/azuredeploy.json",
    "editableTestModeVariable": "ANF_TestMode",
    "editableCapacityPoolResourceIdVariable": "ANF_CapacityPoolResourceId",
    "editableLargeVolumeMaximumSizeVariable": "ANF_LargeVolumeMaximumSizeGiB"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "name": "anf-capacity-autoscale-gov",
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "[variables('sharedTemplateUri')]",
          "contentVersion": "1.0.0.0"
        },
        "parameters": {
          "automationAccountName": {
            "value": "[parameters('automationAccountName')]"
          },
          "capacityPoolResourceId": {
            "value": "[parameters('capacityPoolResourceId')]"
          },
          "testMode": {
            "value": "[parameters('testMode')]"
          },
          "capacityResizeThreshold": {
            "value": "[parameters('capacityResizeThreshold')]"
          },
          "minimumFreeSpaceGiB": {
            "value": "[parameters('minimumFreeSpaceGiB')]"
          },
          "minimumVolumeGrowthPercent": {
            "value": "[parameters('minimumVolumeGrowthPercent')]"
          },
          "maximumVolumeGrowthPercent": {
            "value": "[parameters('maximumVolumeGrowthPercent')]"
          },
          "capacityLookBackHours": {
            "value": "[parameters('capacityLookBackHours')]"
          },
          "volumeMinThroughputMap": {
            "value": "[parameters('volumeMinThroughputMap')]"
          },
          "scheduleStartDelayMinutes": {
            "value": "[parameters('scheduleStartDelayMinutes')]"
          },
          "runbookScriptUri": {
            "value": "[parameters('runbookScriptUri')]"
          }
        }
      }
    }
  ],
  "outputs": {
    "testModeVariable": {
      "type": "string",
      "value": "[variables('editableTestModeVariable')]"
    },
    "capacityPoolResourceIdVariable": {
      "type": "string",
      "value": "[variables('editableCapacityPoolResourceIdVariable')]"
    },
    "largeVolumeMaximumSizeVariable": {
      "type": "string",
      "value": "[variables('editableLargeVolumeMaximumSizeVariable')]"
    },
    "template": {
      "type": "string",
      "value": "Azure Government wrapper for ANF Capacity Autoscale deploy template."
    }
  }
}
