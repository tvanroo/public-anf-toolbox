{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "automationAccountName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional Automation Account name. Leave blank to generate one."
      }
    },
    "anfAccountName": {
      "type": "string",
      "metadata": {
        "description": "Target Azure NetApp Files account name."
      }
    },
    "anfPoolName": {
      "type": "string",
      "metadata": {
        "description": "Target Azure NetApp Files capacity pool name."
      }
    },
    "testMode": {
      "type": "string",
      "defaultValue": "Yes",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Yes = preview only. No = apply live capacity and throughput changes."
      }
    },
    "capacityResizeThreshold": {
      "type": "int",
      "defaultValue": 99,
      "minValue": 1,
      "maxValue": 100,
      "metadata": {
        "description": "Expand a volume when max observed utilization is at or above this percent."
      }
    },
    "minimumFreeSpaceGiB": {
      "type": "int",
      "defaultValue": 256,
      "minValue": 1,
      "metadata": {
        "description": "Expand a volume when free space is at or below this value. Also used in target size calculations."
      }
    },
    "minimumVolumeGrowthPercent": {
      "type": "int",
      "defaultValue": 0,
      "minValue": 0,
      "metadata": {
        "description": "Minimum percent growth applied when expanding a volume."
      }
    },
    "maximumVolumeGrowthPercent": {
      "type": "int",
      "defaultValue": 10000000,
      "minValue": 1,
      "metadata": {
        "description": "Maximum percent growth allowed in one run."
      }
    },
    "capacityLookBackHours": {
      "type": "int",
      "defaultValue": 24,
      "minValue": 1,
      "metadata": {
        "description": "Lookback window for the VolumeLogicalSize metric."
      }
    },
    "volumeMinThroughputMap": {
      "type": "string",
      "defaultValue": "{}",
      "metadata": {
        "description": "JSON map of volume name to minimum MiB/s, for example {\"vol1\":10,\"vol2\":15}. Leave {} if not needed."
      }
    },
    "maxThroughputPerTiB": {
      "type": "int",
      "defaultValue": 68,
      "minValue": 1,
      "metadata": {
        "description": "Classic manual QoS cap for calculated throughput per TiB. Flexible service level does not derive throughput from pool size."
      }
    },
    "minimumPoolThroughputMibps": {
      "type": "int",
      "defaultValue": 128,
      "minValue": 1,
      "metadata": {
        "description": "Flexible service level pool throughput floor in MiB/s."
      }
    },
    "largeVolumeLimitMode": {
      "type": "string",
      "defaultValue": "Auto",
      "allowedValues": [
        "Auto",
        "Large",
        "Breakthrough",
        "ExtraLargeCoolAccess"
      ],
      "metadata": {
        "description": "Auto detects existing large-volume variants from Azure properties. Explicit modes override the large-volume profile only for volumes already marked as large."
      }
    },
    "regularVolumeMinimumSizeGiB": {
      "type": "int",
      "defaultValue": 50,
      "minValue": 1,
      "metadata": {
        "description": "Regular volume minimum size guard in GiB."
      }
    },
    "regularVolumeMaximumSizeGiB": {
      "type": "int",
      "defaultValue": 102400,
      "minValue": 50,
      "metadata": {
        "description": "Regular volume maximum size guard in GiB."
      }
    },
    "largeVolumeMinimumSizeGiB": {
      "type": "int",
      "defaultValue": 51200,
      "minValue": 1,
      "metadata": {
        "description": "Default large volume minimum size guard in GiB."
      }
    },
    "largeVolumeMaximumSizeGiB": {
      "type": "int",
      "defaultValue": 1048576,
      "minValue": 51200,
      "metadata": {
        "description": "Default large volume maximum size guard in GiB."
      }
    },
    "breakthroughLargeVolumeMinimumSizeGiB": {
      "type": "int",
      "defaultValue": 2400,
      "minValue": 1,
      "metadata": {
        "description": "Breakthrough large volume minimum size guard in GiB."
      }
    },
    "breakthroughLargeVolumeMaximumSizeGiB": {
      "type": "int",
      "defaultValue": 2457600,
      "minValue": 2400,
      "metadata": {
        "description": "Breakthrough large volume maximum size guard in GiB."
      }
    },
    "extraLargeCoolAccessVolumeMinimumSizeGiB": {
      "type": "int",
      "defaultValue": 2400,
      "minValue": 1,
      "metadata": {
        "description": "Extra-large cool-access volume minimum size guard in GiB."
      }
    },
    "extraLargeCoolAccessVolumeMaximumSizeGiB": {
      "type": "int",
      "defaultValue": 7549747,
      "minValue": 2400,
      "metadata": {
        "description": "Extra-large cool-access volume maximum size guard in GiB."
      }
    },
    "scheduleTimeZone": {
      "type": "string",
      "defaultValue": "UTC",
      "metadata": {
        "description": "Time zone used by the recurring run schedule."
      }
    },
    "scheduleStartTimeUtc": {
      "type": "string",
      "defaultValue": "[dateTimeAdd(utcNow('u'), 'PT20M')]",
      "metadata": {
        "description": "UTC start time for the first run. Default is deployment time + 20 minutes."
      }
    },
    "runbookScriptUri": {
      "type": "string",
      "defaultValue": "https://raw.githubusercontent.com/tvanroo/public-anf-toolbox/codex/wip-anf-capacity-autoscale-fsl/ANF%20Capacity%20Autoscale/ANF-Capacity-Autoscale.ps1",
      "metadata": {
        "description": "Source URL of the runbook script file to import and publish."
      }
    }
  },
  "variables": {
    "sharedTemplateUri": "https://raw.githubusercontent.com/tvanroo/public-anf-toolbox/codex/wip-anf-capacity-autoscale-fsl/ANF%20Capacity%20Autoscale/deploy/azuredeploy.json",
    "editableTestModeVariable": "ANF_TestMode",
    "editableLargeVolumeModeVariable": "ANF_LargeVolumeLimitMode"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "name": "anf-capacity-autoscale-gov",
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "[variables('sharedTemplateUri')]",
          "contentVersion": "1.0.0.0"
        },
        "parameters": {
          "automationAccountName": {
            "value": "[parameters('automationAccountName')]"
          },
          "anfAccountName": {
            "value": "[parameters('anfAccountName')]"
          },
          "anfPoolName": {
            "value": "[parameters('anfPoolName')]"
          },
          "testMode": {
            "value": "[parameters('testMode')]"
          },
          "capacityResizeThreshold": {
            "value": "[parameters('capacityResizeThreshold')]"
          },
          "minimumFreeSpaceGiB": {
            "value": "[parameters('minimumFreeSpaceGiB')]"
          },
          "minimumVolumeGrowthPercent": {
            "value": "[parameters('minimumVolumeGrowthPercent')]"
          },
          "maximumVolumeGrowthPercent": {
            "value": "[parameters('maximumVolumeGrowthPercent')]"
          },
          "capacityLookBackHours": {
            "value": "[parameters('capacityLookBackHours')]"
          },
          "volumeMinThroughputMap": {
            "value": "[parameters('volumeMinThroughputMap')]"
          },
          "maxThroughputPerTiB": {
            "value": "[parameters('maxThroughputPerTiB')]"
          },
          "minimumPoolThroughputMibps": {
            "value": "[parameters('minimumPoolThroughputMibps')]"
          },
          "largeVolumeLimitMode": {
            "value": "[parameters('largeVolumeLimitMode')]"
          },
          "regularVolumeMinimumSizeGiB": {
            "value": "[parameters('regularVolumeMinimumSizeGiB')]"
          },
          "regularVolumeMaximumSizeGiB": {
            "value": "[parameters('regularVolumeMaximumSizeGiB')]"
          },
          "largeVolumeMinimumSizeGiB": {
            "value": "[parameters('largeVolumeMinimumSizeGiB')]"
          },
          "largeVolumeMaximumSizeGiB": {
            "value": "[parameters('largeVolumeMaximumSizeGiB')]"
          },
          "breakthroughLargeVolumeMinimumSizeGiB": {
            "value": "[parameters('breakthroughLargeVolumeMinimumSizeGiB')]"
          },
          "breakthroughLargeVolumeMaximumSizeGiB": {
            "value": "[parameters('breakthroughLargeVolumeMaximumSizeGiB')]"
          },
          "extraLargeCoolAccessVolumeMinimumSizeGiB": {
            "value": "[parameters('extraLargeCoolAccessVolumeMinimumSizeGiB')]"
          },
          "extraLargeCoolAccessVolumeMaximumSizeGiB": {
            "value": "[parameters('extraLargeCoolAccessVolumeMaximumSizeGiB')]"
          },
          "scheduleTimeZone": {
            "value": "[parameters('scheduleTimeZone')]"
          },
          "scheduleStartTimeUtc": {
            "value": "[parameters('scheduleStartTimeUtc')]"
          },
          "runbookScriptUri": {
            "value": "[parameters('runbookScriptUri')]"
          }
        }
      }
    }
  ],
  "outputs": {
    "testModeVariable": {
      "type": "string",
      "value": "[variables('editableTestModeVariable')]"
    },
    "largeVolumeModeVariable": {
      "type": "string",
      "value": "[variables('editableLargeVolumeModeVariable')]"
    },
    "template": {
      "type": "string",
      "value": "Azure Government wrapper for ANF Capacity Autoscale WIP deploy template."
    }
  }
}
