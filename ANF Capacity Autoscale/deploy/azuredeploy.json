{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "automationAccountName": {
      "type": "string",
      "defaultValue": "ANF-Capacity-Autoscale",
      "metadata": {
        "description": "Automation Account name. Change this if the name already exists in the deployment resource group, or clear it to generate a unique name."
      }
    },
    "capacityPoolResourceId": {
      "type": "string",
      "metadata": {
        "description": "Full Resource ID of the target Azure NetApp Files capacity pool. Example: /subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/Microsoft.NetApp/netAppAccounts/<account>/capacityPools/<pool>"
      }
    },
    "testMode": {
      "type": "string",
      "defaultValue": "Yes",
      "allowedValues": [
        "Yes",
        "No"
      ],
      "metadata": {
        "description": "Yes = preview only. No = apply live capacity and throughput changes."
      }
    },
    "capacityResizeThreshold": {
      "type": "int",
      "defaultValue": 99,
      "minValue": 1,
      "maxValue": 100,
      "metadata": {
        "description": "Expand a volume when max observed utilization is at or above this percent."
      }
    },
    "minimumFreeSpaceGiB": {
      "type": "int",
      "defaultValue": 256,
      "minValue": 1,
      "metadata": {
        "description": "Expand a volume when free space is at or below this value. Also used in target size calculations."
      }
    },
    "minimumVolumeGrowthPercent": {
      "type": "int",
      "defaultValue": 0,
      "minValue": 0,
      "metadata": {
        "description": "Minimum percent growth applied when expanding a volume."
      }
    },
    "maximumVolumeGrowthPercent": {
      "type": "int",
      "defaultValue": 10000000,
      "minValue": 1,
      "metadata": {
        "description": "Maximum percent growth allowed in one run."
      }
    },
    "capacityLookBackHours": {
      "type": "int",
      "defaultValue": 24,
      "minValue": 1,
      "metadata": {
        "description": "Lookback window for the VolumeLogicalSize metric."
      }
    },
    "volumeMinThroughputMap": {
      "type": "string",
      "defaultValue": "{}",
      "metadata": {
        "description": "JSON map of volume name to minimum MiB/s, for example {\"vol1\":10,\"vol2\":15}. Leave {} if not needed."
      }
    },
    "scheduleStartDelayMinutes": {
      "type": "int",
      "defaultValue": 20,
      "minValue": 1,
      "metadata": {
        "description": "Minutes from deployment time until the first scheduled run starts."
      }
    },
    "scheduleBaseTimeUtc": {
      "type": "string",
      "defaultValue": "[utcNow('u')]",
      "metadata": {
        "description": "Deployment timestamp used to calculate the first scheduled run. Leave the default value."
      }
    },
    "runbookScriptUri": {
      "type": "string",
      "defaultValue": "https://raw.githubusercontent.com/tvanroo/public-anf-toolbox/codex/wip-anf-capacity-autoscale-fsl/ANF%20Capacity%20Autoscale/ANF-Capacity-Autoscale.ps1",
      "metadata": {
        "description": "Source URL of the runbook script file to import and publish."
      }
    }
  },
  "variables": {
    "automationAccountName": "[if(empty(parameters('automationAccountName')), toLower(concat('aa-anf-capacity-', take(uniqueString(resourceGroup().id, deployment().name), 8))), parameters('automationAccountName'))]",
    "runbookName": "ANF-Capacity-Autoscale",
    "scheduleName": "anf-capacity-autoscale-4h",
    "jobScheduleName": "[guid(resourceGroup().id, variables('automationAccountName'), variables('runbookName'), variables('scheduleName'))]",
    "anfAdministratorRoleName": "Azure NetApp Files Administrator",
    "anfAdministratorRoleDefinitionId": "f5db7409-a2c6-4d0c-8cf4-412ac01a38df",
    "monitoringReaderRoleDefinitionId": "43d0d8ad-25c7-4714-9337-8ba259a9fe05",
    "largeVolumeMaximumSizeGiB": 1048576,
    "standardTags": {
      "managed-by": "public-anf-toolbox",
      "solution": "anf-capacity-autoscale",
      "repository": "https://github.com/tvanroo/public-anf-toolbox",
      "documentation": "https://github.com/tvanroo/public-anf-toolbox/tree/codex/wip-anf-capacity-autoscale-fsl/ANF%20Capacity%20Autoscale",
      "script": "ANF-Capacity-Autoscale.ps1",
      "status": "WIP"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Automation/automationAccounts",
      "apiVersion": "2023-11-01",
      "name": "[variables('automationAccountName')]",
      "location": "[resourceGroup().location]",
      "identity": {
        "type": "SystemAssigned"
      },
      "tags": "[variables('standardTags')]",
      "properties": {
        "sku": {
          "name": "Basic"
        },
        "publicNetworkAccess": true
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/modules",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/Az.Accounts')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "contentLink": {
          "uri": "https://www.powershellgallery.com/api/v2/package/Az.Accounts"
        }
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceGroup().id, variables('automationAccountName'), variables('anfAdministratorRoleDefinitionId'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('anfAdministratorRoleDefinitionId'))]",
        "principalId": "[reference(resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName')), '2023-11-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceGroup().id, variables('automationAccountName'), variables('monitoringReaderRoleDefinitionId'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('monitoringReaderRoleDefinitionId'))]",
        "principalId": "[reference(resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName')), '2023-11-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_TenantId')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Target Azure tenant ID.",
        "value": "[concat('\"', tenant().tenantId, '\"')]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_CapacityPoolResourceId')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Full Resource ID of the target Azure NetApp Files capacity pool.",
        "value": "[concat('\"', parameters('capacityPoolResourceId'), '\"')]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_TestMode')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Runbook mode. Yes=preview only. No=live changes.",
        "value": "[concat('\"', parameters('testMode'), '\"')]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_CapacityResizeThreshold')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Resize threshold percent.",
        "value": "[string(parameters('capacityResizeThreshold'))]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_MinimumFreeSpaceGiB')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Minimum free space in GiB.",
        "value": "[string(parameters('minimumFreeSpaceGiB'))]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_MinimumVolumeGrowthPercent')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Minimum percent growth for expansion.",
        "value": "[string(parameters('minimumVolumeGrowthPercent'))]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_MaximumVolumeGrowthPercent')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Maximum percent growth per run.",
        "value": "[string(parameters('maximumVolumeGrowthPercent'))]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_CapacityLookBackHours')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Capacity metric lookback hours.",
        "value": "[string(parameters('capacityLookBackHours'))]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_VolumeMinThroughputMap')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "JSON map of volume name to minimum MiB/s.",
        "value": "[concat('\"', parameters('volumeMinThroughputMap'), '\"')]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/variables",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/ANF_LargeVolumeMaximumSizeGiB')]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "isEncrypted": false,
        "description": "Large volume maximum size in GiB. Default is 1 PiB; edit this Automation variable after deployment if a target region supports more.",
        "value": "[string(variables('largeVolumeMaximumSizeGiB'))]"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/runbooks",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/', variables('runbookName'))]",
      "location": "[resourceGroup().location]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts/modules', variables('automationAccountName'), 'Az.Accounts')]"
      ],
      "tags": "[variables('standardTags')]",
      "properties": {
        "description": "ANF Capacity Autoscale runbook. WIP script for all service levels and large-volume variants.",
        "runbookType": "PowerShell72",
        "logProgress": true,
        "logVerbose": true,
        "publishContentLink": {
          "uri": "[parameters('runbookScriptUri')]",
          "version": "1.0.0.0"
        }
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/schedules",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/', variables('scheduleName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName'))]"
      ],
      "properties": {
        "description": "Every 4 hours schedule for ANF Capacity Autoscale runbook.",
        "startTime": "[dateTimeAdd(parameters('scheduleBaseTimeUtc'), concat('PT', parameters('scheduleStartDelayMinutes'), 'M'))]",
        "frequency": "Hour",
        "interval": 4,
        "timeZone": "UTC"
      }
    },
    {
      "type": "Microsoft.Automation/automationAccounts/jobSchedules",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('automationAccountName'), '/', variables('jobScheduleName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Automation/automationAccounts/runbooks', variables('automationAccountName'), variables('runbookName'))]",
        "[resourceId('Microsoft.Automation/automationAccounts/schedules', variables('automationAccountName'), variables('scheduleName'))]"
      ],
      "properties": {
        "schedule": {
          "name": "[variables('scheduleName')]"
        },
        "runbook": {
          "name": "[variables('runbookName')]"
        }
      }
    }
  ],
  "outputs": {
    "automationAccountName": {
      "type": "string",
      "value": "[variables('automationAccountName')]"
    },
    "runbookName": {
      "type": "string",
      "value": "[variables('runbookName')]"
    },
    "testModeVariable": {
      "type": "string",
      "value": "ANF_TestMode"
    },
    "capacityPoolResourceIdVariable": {
      "type": "string",
      "value": "ANF_CapacityPoolResourceId"
    },
    "largeVolumeMaximumSizeVariable": {
      "type": "string",
      "value": "ANF_LargeVolumeMaximumSizeGiB"
    },
    "managedIdentityPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Automation/automationAccounts', variables('automationAccountName')), '2023-11-01', 'Full').identity.principalId]"
    },
    "rbac": {
      "type": "string",
      "value": "[concat('Assigned ', variables('anfAdministratorRoleName'), ' and Monitoring Reader at the deployment resource group scope. Deploy into the ANF resource group for seamless access.')]"
    }
  }
}
